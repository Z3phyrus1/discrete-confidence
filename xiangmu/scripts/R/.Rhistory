# ------------------------------------------------------#
# run simulation
sim_data <- {}
sim_fit  <- {}
n_par <- c(0 , 1, 2)
cat("Model recovery simulation started on ", date(), "\n")
for (id in 1:n_id) {
d <- data.frame(
s1 = runif(n_trial, min = -R, max = R),
